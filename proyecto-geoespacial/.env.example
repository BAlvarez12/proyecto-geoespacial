# Copia este archivo a .env y sustituye los valores de ejemplo.
#   cp .env.example .env

# Base de datos (PostGIS). Usadas por el servicio db y el backend.
POSTGRES_DB=geoapp
POSTGRES_USER=geoapp
POSTGRES_PASSWORD=cambia_esta_contraseña

# Puerto HTTP del backend dentro de la red Docker (Nginx hace proxy aquí).
PORT=3000

# Solo se ejecuta el backend en tu máquina, fuera de Docker:
# DB_HOST=localhost
# POSTGRES_PORT=5432
